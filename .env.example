# ─────────────────────────────────────────────
# UNIUTY Portal — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=uniuty_db
DB_USER=uniuty_admin
DB_PASSWORD=your_secure_password_here

# JWT Secret (change this to a long random string)
JWT_SECRET=uniuty_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=8h

# Session Secret
SESSION_SECRET=uniuty_session_secret_change_this

# Biometric Hardware Settings
# ─────────────────────────────
# DigitalPersona U.are.U Fingerprint Reader
FINGERPRINT_SDK=digitalpersona
FINGERPRINT_PORT=COM3          # Windows: COM3, Linux: /dev/ttyUSB0
FINGERPRINT_BAUD=115200
FINGERPRINT_TIMEOUT=10000      # 10 seconds scan timeout
FINGERPRINT_MIN_QUALITY=60     # Minimum match quality score (0-100)
FINGERPRINT_MATCH_THRESHOLD=40 # Match score threshold (40 = good balance)

# Suprema Biostar Retina Scanner
RETINA_SCANNER_IP=192.168.1.100
RETINA_SCANNER_PORT=4433
RETINA_API_KEY=your_suprema_api_key

# AWS Rekognition (Facial Recognition)
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_FACE_COLLECTION=uniuty_faces
AWS_MIN_CONFIDENCE=90          # Minimum face match confidence (%)

# Email (SMTP)
SMTP_HOST=smtp.uniuty.edu.ng
SMTP_PORT=587
SMTP_USER=noreply@uniuty.edu.ng
SMTP_PASSWORD=your_smtp_password

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=104857600        # 100MB in bytes
